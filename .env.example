# Copy relevant lines to your shell profile. Do not commit real values.

# Required for remote submit script generation.
# Must contain a {vasp_bin} placeholder, for example:
#   export VIBEDFT_VASP_CMD='mpirun {vasp_bin}'
export VIBEDFT_VASP_CMD="<site-specific-vap-command-with-{vasp_bin}>"

# Required for POTCAR generation fallback.
export VIBEDFT_POTCAR_DIR="<path-to-your-potpaw-library>"

# Optional: your own private runtime notes live outside git, e.g.
#   .local/runtime-profile.md
